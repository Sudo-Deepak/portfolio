---
import { Icon } from 'astro-icon/components';
import { site, nav } from '../data/site';

const socials = [
  { name: 'github', href: site.socials.github, label: 'GitHub' },
  { name: 'linkedin', href: site.socials.linkedin, label: 'LinkedIn' },
  { name: 'youtube', href: site.socials.youtube, label: 'YouTube' },
  { name: 'instagram', href: site.socials.instagram, label: 'Instagram' },
];
const year = 2026;
---

<footer class="border-t border-slate-200 py-10 dark:border-line">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 md:flex-row md:justify-between">
    <div class="text-center md:text-left">
      <p class="font-semibold">{site.name}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400">{site.role} · {site.location}</p>
    </div>

    <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm" aria-label="Footer">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-slate-500 transition-colors hover:text-brand-600 dark:text-slate-400 dark:hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex gap-3">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={s.label}
            class="text-slate-400 transition-colors hover:text-brand-600 dark:hover:text-white"
          >
            <Icon name={`lucide:${s.name}`} class="h-5 w-5" />
          </a>
        ))
      }
    </div>
  </div>

  <p class="mt-8 text-center text-sm text-slate-400">
    © {year} {site.name}. Built with Astro & Tailwind CSS.
  </p>
</footer>
