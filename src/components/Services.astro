---
import { Icon } from 'astro-icon/components';
import SectionHeading from './SectionHeading.astro';
import { services, availability } from '../data/site';
---

<section id="services" class="mx-auto max-w-6xl px-6 py-24">
  <SectionHeading
    eyebrow="Services"
    title="How I can help"
    subtitle="From architecture to production — here's how we can work together, whether you're hiring or building."
  />

  <div class="grid gap-6 sm:grid-cols-2">
    {
      services.map((s, i) => (
        <div
          data-reveal
          style={`--reveal-delay:${(i % 2) * 100}ms`}
          class="group rounded-2xl border border-slate-200 bg-white p-7 transition-all hover:-translate-y-1 hover:border-brand-500/50 hover:shadow-glow dark:border-line dark:bg-surface"
        >
          <div class="flex items-center gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-600/10 text-brand-600 transition-colors group-hover:bg-brand-600 group-hover:text-white dark:text-brand-400">
              <Icon name={`lucide:${s.icon}`} class="h-6 w-6" />
            </span>
            <h3 class="text-lg font-semibold">{s.title}</h3>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{s.body}</p>

          <ul class="mt-5 grid gap-2">
            {s.includes.map((item) => (
              <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
                <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <!-- CTA -->
  <div
    data-reveal
    class="mt-8 overflow-hidden rounded-3xl border border-brand-500/30 bg-gradient-to-br from-brand-600/10 to-accent-500/10 p-8 text-center sm:p-10"
  >
    <p class="inline-flex items-center gap-2 text-sm font-medium text-brand-700 dark:text-brand-300">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
      </span>
      {availability}
    </p>
    <h3 class="mx-auto mt-4 max-w-xl text-2xl font-bold tracking-tight">
      Have a project or role in mind? Let's talk.
    </h3>
    <a
      href="#contact"
      class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-glow transition-transform hover:-translate-y-0.5 hover:bg-brand-500"
    >
      Start a conversation
      <Icon name="lucide:arrow-right" class="h-4 w-4" />
    </a>
  </div>
</section>
