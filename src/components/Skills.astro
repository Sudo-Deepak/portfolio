---
import { Icon } from 'astro-icon/components';
import SectionHeading from './SectionHeading.astro';
import { skillGroups } from '../data/site';
---

<section id="skills" class="bg-slate-50 py-24 dark:bg-surface-2">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      eyebrow="Technical Skills"
      title="The stack I work with"
      subtitle="A backend-heavy toolkit spanning frameworks, data, cloud, and enterprise integrations."
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group, i) => (
          <div
            data-reveal
            style={`--reveal-delay:${(i % 3) * 80}ms`}
            class="rounded-2xl border border-slate-200 bg-white p-6 transition-all hover:border-brand-500/50 hover:shadow-glow dark:border-line dark:bg-surface"
          >
            <div class="mb-4 flex items-center gap-3">
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-600/10 text-brand-600 dark:text-brand-400">
                <Icon name={`lucide:${group.icon}`} class="h-5 w-5" />
              </span>
              <h3 class="font-semibold">{group.title}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-700 dark:border-line dark:bg-ink dark:text-slate-300">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
