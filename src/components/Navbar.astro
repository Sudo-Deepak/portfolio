---
import { Icon } from 'astro-icon/components';
import { site, nav } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resume = `${base}/${site.resumeUrl}`;
---

<header
  id="site-nav"
  class="fixed top-0 z-50 w-full border-b border-transparent transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="#" class="group flex items-center gap-2 text-lg font-bold tracking-tight">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-600 text-sm font-black text-white shadow-glow">
        DK
      </span>
      <span class="hidden sm:inline">{site.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:text-brand-600 dark:text-slate-300 dark:hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
        class="grid h-9 w-9 place-items-center rounded-lg border border-slate-300 text-slate-600 transition-colors hover:border-brand-500 hover:text-brand-600 dark:border-line dark:text-slate-300 dark:hover:text-white"
      >
        <Icon name="lucide:sun" class="hidden h-5 w-5 dark:block" />
        <Icon name="lucide:moon" class="h-5 w-5 dark:hidden" />
      </button>

      <a
        href={resume}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-glow transition-transform hover:-translate-y-0.5 hover:bg-brand-500 md:inline-flex"
      >
        <Icon name="lucide:download" class="h-4 w-4" />
        Resume
      </a>

      <button
        id="menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        class="grid h-9 w-9 place-items-center rounded-lg border border-slate-300 text-slate-600 dark:border-line dark:text-slate-300 md:hidden"
      >
        <Icon name="lucide:menu" class="menu-open h-5 w-5" />
        <Icon name="lucide:x" class="menu-close hidden h-5 w-5" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white/95 px-6 py-4 backdrop-blur md:hidden dark:border-line dark:bg-ink/95"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="mobile-link rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-surface"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={resume}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white"
      >
        <Icon name="lucide:download" class="h-4 w-4" />
        Download Resume
      </a>
    </nav>
  </div>
</header>

<script>
  // Theme toggle with persistence
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const menuBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = menuBtn?.querySelector('.menu-open');
  const closeIcon = menuBtn?.querySelector('.menu-close');

  function setMenu(open: boolean) {
    menu?.classList.toggle('hidden', !open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
    menuBtn?.setAttribute('aria-expanded', String(open));
  }
  menuBtn?.addEventListener('click', () => setMenu(menu?.classList.contains('hidden') ?? true));
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));

  // Navbar background on scroll
  const navEl = document.getElementById('site-nav');
  const onScroll = () => {
    const scrolled = window.scrollY > 12;
    navEl?.classList.toggle('border-slate-200', scrolled);
    navEl?.classList.toggle('dark:border-line', scrolled);
    navEl?.classList.toggle('bg-white/80', scrolled);
    navEl?.classList.toggle('dark:bg-ink/80', scrolled);
    navEl?.classList.toggle('backdrop-blur-md', scrolled);
    navEl?.classList.toggle('shadow-sm', scrolled);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
