---
import { Icon } from 'astro-icon/components';
import SectionHeading from './SectionHeading.astro';
import { site } from '../data/site';

const socials = [
  { name: 'linkedin', label: 'LinkedIn', href: site.socials.linkedin },
  { name: 'github', label: 'GitHub', href: site.socials.github },
  { name: 'youtube', label: 'YouTube', href: site.socials.youtube },
  { name: 'instagram', label: 'Instagram', href: site.socials.instagram },
];
---

<section id="contact" class="mx-auto max-w-6xl px-6 py-24">
  <SectionHeading
    eyebrow="Contact"
    title="Let's build something"
    subtitle="Open to backend-focused, integration-heavy, or full-stack projects. Drop me a message."
  />

  <div class="grid gap-10 md:grid-cols-2 md:gap-12">
    <!-- Left: info -->
    <div data-reveal class="space-y-6">
      <p class="text-slate-600 dark:text-slate-400">
        Whether it's a collaboration, a role, or just a technical conversation — I'd love to hear from you. 👋
      </p>

      <a
        href={site.socials.email}
        class="group flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-4 transition-all hover:border-brand-500/50 hover:shadow-glow dark:border-line dark:bg-surface"
      >
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-brand-600/10 text-brand-600 dark:text-brand-400">
          <Icon name="lucide:mail" class="h-5 w-5" />
        </span>
        <span class="min-w-0">
          <span class="block text-xs uppercase tracking-wider text-slate-400">Email</span>
          <span class="block truncate text-sm font-medium group-hover:text-brand-600 dark:group-hover:text-white">
            {site.email}
          </span>
        </span>
      </a>

      <div class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 dark:border-line dark:bg-surface">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-brand-600/10 text-brand-600 dark:text-brand-400">
          <Icon name="lucide:map-pin" class="h-5 w-5" />
        </span>
        <span>
          <span class="block text-xs uppercase tracking-wider text-slate-400">Location</span>
          <span class="block text-sm font-medium">{site.location}</span>
        </span>
      </div>

      <div>
        <p class="mb-3 text-sm uppercase tracking-wider text-slate-400">Find me on</p>
        <div class="flex flex-wrap gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
                class="grid h-11 w-11 place-items-center rounded-lg border border-slate-200 text-slate-500 transition-all hover:-translate-y-0.5 hover:border-brand-500 hover:text-brand-600 dark:border-line dark:text-slate-300 dark:hover:text-white"
              >
                <Icon name={`lucide:${s.name}`} class="h-5 w-5" />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Right: form -->
    <form
      id="contact-form"
      data-reveal
      style="--reveal-delay:120ms"
      class="space-y-4 rounded-2xl border border-slate-200 bg-white p-6 dark:border-line dark:bg-surface"
    >
      <input type="hidden" name="_subject" value="New Contact Message from Portfolio" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

      <div>
        <label for="name" class="mb-1.5 block text-sm font-medium">Name</label>
        <input
          id="name"
          type="text"
          name="name"
          placeholder="Your name"
          required
          class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 dark:border-line dark:bg-ink"
        />
      </div>

      <div>
        <label for="email" class="mb-1.5 block text-sm font-medium">Email</label>
        <input
          id="email"
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 dark:border-line dark:bg-ink"
        />
      </div>

      <div>
        <label for="message" class="mb-1.5 block text-sm font-medium">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Tell me about your project..."
          required
          class="w-full resize-y rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 dark:border-line dark:bg-ink"
        ></textarea>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-glow transition hover:bg-brand-500 disabled:opacity-50"
      >
        <Icon name="lucide:send" class="h-4 w-4" />
        Send Message
      </button>

      <p id="response-msg" class="hidden text-center text-sm"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const msg = document.getElementById('response-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !msg) return;

    btn.disabled = true;
    const original = btn.innerHTML;
    btn.textContent = 'Sending...';
    msg.classList.add('hidden');

    try {
      const res = await fetch('https://formsubmit.co/ajax/c2f96278ee2468d87acc0b5221eb089d', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) throw new Error('Request failed');
      msg.textContent = "Thanks! Your message has been sent.";
      msg.className = 'text-center text-sm text-green-600 dark:text-green-400';
      form.reset();
    } catch {
      msg.textContent = 'Something went wrong. Please try again.';
      msg.className = 'text-center text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });
</script>
