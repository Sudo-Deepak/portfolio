---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import SectionHeading from './SectionHeading.astro';
import { projects } from '../data/site';
import type { ImageMetadata } from 'astro';

// Eagerly import all project images so Astro can optimize them at build time.
const imageModules = import.meta.glob<{ default: ImageMetadata }>('../assets/projects/*.png', {
  eager: true,
});

const getImage = (name: string) => imageModules[`../assets/projects/${name}.png`]?.default;

const featured = projects.find((p) => p.featured) ?? projects[0];
const rest = projects.filter((p) => p !== featured);
const featuredImg = getImage(featured.image);
---

<section id="projects" class="bg-slate-50 py-24 dark:bg-surface-2">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      eyebrow="Projects"
      title="Selected work"
      subtitle="Enterprise platforms and products I've architected and built — with my role and the outcomes they delivered."
    />

    <!-- Featured project -->
    <article
      data-reveal
      class="group mb-8 grid overflow-hidden rounded-3xl border border-slate-200 bg-white transition-all hover:border-brand-500/50 hover:shadow-glow-lg md:grid-cols-2 dark:border-line dark:bg-surface"
    >
      <div class="relative min-h-64 overflow-hidden md:order-last">
        {
          featuredImg && (
            <Image
              src={featuredImg}
              alt={featured.title}
              widths={[500, 900]}
              sizes="(max-width: 768px) 100vw, 50vw"
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent md:bg-gradient-to-r"></div>
        <span
          class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white shadow-glow"
        >
          <Icon name="lucide:star" class="h-3.5 w-3.5" />
          Featured
        </span>
      </div>

      <div class="flex flex-col justify-center p-7 sm:p-9">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-medium text-slate-500 dark:border-line dark:text-slate-400">
            {featured.domain}
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-600/10 px-3 py-1 text-xs font-semibold text-brand-700 dark:text-brand-300">
            <Icon name="lucide:briefcase" class="h-3.5 w-3.5" />
            {featured.role}
          </span>
        </div>
        <h3 class="text-2xl font-bold tracking-tight">{featured.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{featured.summary}</p>

        {
          featured.stats && (
            <div class="mt-6 grid grid-cols-3 gap-3">
              {featured.stats.map((s) => (
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center dark:border-line dark:bg-ink">
                  <p class="text-lg font-extrabold text-brand-600 dark:text-brand-400">{s.value}</p>
                  <p class="mt-0.5 text-[11px] leading-tight text-slate-500 dark:text-slate-400">{s.label}</p>
                </div>
              ))}
            </div>
          )
        }

        <div class="mt-6 flex flex-wrap gap-2">
          {
            featured.tech.map((t) => (
              <span class="rounded-md bg-brand-600/10 px-2 py-0.5 text-xs font-medium text-brand-700 dark:text-brand-300">
                {t}
              </span>
            ))
          }
        </div>
      </div>
    </article>

    <!-- Remaining projects -->
    <div class="grid gap-6 sm:grid-cols-2">
      {
        rest.map((project, i) => {
          const img = getImage(project.image);
          return (
            <article
              data-reveal
              style={`--reveal-delay:${(i % 2) * 100}ms`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition-all hover:-translate-y-1 hover:border-brand-500/50 hover:shadow-glow-lg dark:border-line dark:bg-surface"
            >
              <div class="relative aspect-[16/9] overflow-hidden">
                {img && (
                  <Image
                    src={img}
                    alt={project.title}
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent" />
                <span class="absolute left-3 top-3 rounded-full bg-ink/70 px-3 py-1 text-xs font-medium text-white backdrop-blur">
                  {project.domain}
                </span>
              </div>

              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-lg font-semibold leading-snug">{project.title}</h3>

                <p class="mt-1.5 inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 dark:text-slate-400">
                  <Icon name="lucide:briefcase" class="h-3.5 w-3.5 text-brand-500" />
                  {project.role}
                </p>

                {project.outcome && (
                  <p class="mt-3 flex items-start gap-2 rounded-lg bg-brand-600/10 px-3 py-2 text-sm font-medium text-brand-700 dark:text-brand-300">
                    <Icon name="lucide:trending-up" class="mt-0.5 h-4 w-4 shrink-0" />
                    {project.outcome}
                  </p>
                )}

                <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                  {project.summary}
                </p>

                <ul class="mt-4 grid gap-1.5">
                  {project.highlights.slice(0, 3).map((h) => (
                    <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
                      <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-5 flex flex-wrap gap-2 border-t border-slate-100 pt-4 dark:border-line">
                  {project.tech.map((t) => (
                    <span class="rounded-md bg-brand-600/10 px-2 py-0.5 text-xs font-medium text-brand-700 dark:text-brand-300">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
