---
import { Icon } from 'astro-icon/components';
import SectionHeading from './SectionHeading.astro';
import { experience } from '../data/site';
---

<section id="experience" class="mx-auto max-w-4xl px-6 py-24">
  <SectionHeading eyebrow="Experience" title="Where I've made an impact" />

  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-3 top-2 bottom-2 w-px bg-gradient-to-b from-brand-500 via-brand-500/40 to-transparent md:left-3"></div>

    <div class="space-y-12">
      {
        experience.map((job, i) => (
          <div data-reveal style={`--reveal-delay:${i * 80}ms`} class="relative pl-12">
            <span class="absolute left-0 top-1.5 grid h-6 w-6 place-items-center rounded-full border-2 border-brand-500 bg-white dark:bg-ink">
              <span class="h-2 w-2 rounded-full bg-brand-500" />
            </span>

            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <h3 class="text-lg font-semibold">
                {job.role} ·{' '}
                <a
                  href={job.link}
                  target="_blank"
                  rel="noopener"
                  class="text-brand-600 hover:underline dark:text-brand-400"
                >
                  {job.company}
                </a>
              </h3>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">{job.period}</p>
            </div>
            <p class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-400">
              <Icon name="lucide:map-pin" class="h-3.5 w-3.5" />
              {job.location}
            </p>

            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{job.summary}</p>

            <ul class="mt-4 space-y-2">
              {job.points.map((point) => (
                <li class="flex gap-2.5 text-sm text-slate-600 dark:text-slate-400">
                  <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
